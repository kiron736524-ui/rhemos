# Rhemos 环境变量样例 —— 复制为 .env.local 并填值。
# .env.local 已 gitignore，绝不提交真实 key。

# 经 Vercel AI Gateway 的模型（脑 / 判图 / 写 prompt / 语音清理 / Gemini fallback）
AI_GATEWAY_API_KEY=

# 文本模型分档（可选）
# 默认：主脑 Sonnet 4.6 控成本；prompt-writer 保持 Opus 4.8；inspect 默认 Sonnet；成本解释用 DeepSeek V4 Flash。
RHEMOS_BRAIN_MODEL=anthropic/claude-sonnet-4.6
RHEMOS_PROMPT_MODEL=anthropic/claude-opus-4.8
RHEMOS_INSPECT_MODEL=anthropic/claude-sonnet-4.6
RHEMOS_COST_MODEL=deepseek/deepseek-v4-flash

# 上下文预算（可选）：最近 N 条消息完整保留，旧用户/助手文本会截断；UI 历史不受影响。
RHEMOS_CONTEXT_RECENT_MESSAGES=8
RHEMOS_CONTEXT_OLD_USER_CHARS=1800
RHEMOS_CONTEXT_OLD_ASSISTANT_CHARS=700

# gpt-image-2 文生图 + 图编辑经 fal.ai
FAL_API_KEY=

# ASR 语音转写经阿里云 DashScope（接语音才需要）
DASHSCOPE_API_KEY=

# 生图 provider 选择：默认 fal（当前唯一真实实现）。
# openai / seedream / gemini 为预留接口——设置后调用会报“尚未实现”，不会伪造出图。
# 未知值会直接报错（避免误以为走了别的 provider）。
IMAGE_PROVIDER=fal
